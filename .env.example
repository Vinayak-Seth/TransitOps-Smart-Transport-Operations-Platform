# Copy this file to ".env" (same folder as package.json) and fill in your own values.
# Vite only exposes vars prefixed with VITE_ to the browser, so keep the prefix exactly as-is.
# Never commit your real .env file — add it to .gitignore.

# --- Supabase (real backend persistence + real document storage) ---
# Get these from: Supabase dashboard → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- EmailJS (real email sending, no backend server needed) ---
# Get these from: emailjs.com dashboard → Email Services / Email Templates / Account → General
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# If any of the above are left blank, TransitOps automatically falls back to
# local-only mode (browser storage, base64 file storage, in-app-only reminders)
# so the app always runs — you just won't get real sync/upload/email until configured.
